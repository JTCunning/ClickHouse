<clickhouse>
    <!--
        Regression coverage for `prometheus.http_path_prefix = "/"` (root mount).

        With the root prefix, Prometheus protocols must be reachable at:
            /<database>/<table>/write
            /<database>/<table>/read
            /<database>/<table>/api/v1/{query,query_range,series,labels,...}

        i.e. with a SINGLE leading slash. Earlier the route regex was assembled as
        `^//[^/]+/[^/]+/...$`, which made the root mount unreachable except via a malformed
        double-slash URL. See `addPrometheusProtocolsToHTTPDefaults`.
    -->
    <prometheus>
        <http_path_prefix>/</http_path_prefix>
    </prometheus>
</clickhouse>
